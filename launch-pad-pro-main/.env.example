# ══════════════════════════════════════════════════════════
# ShalyaMitra Frontend — Environment Variables
# ══════════════════════════════════════════════════════════
# Copy to .env.local and restart dev server.
#
# Production domain layout:
#   shalyamitra.quaasx108.com       → Vercel  (this frontend, always-on)
#   gpu.shalyamitra.quaasx108.com   → Cloudflare → Lightning AI GPU (per-slot only)
#   auth.shalyamitra.quaasx108.com  → Supabase  (optional custom domain)
# ══════════════════════════════════════════════════════════

# ── Supabase (Auth + Database) ────────────────────────────
# Dashboard → Project Settings → API
#   Project URL  → VITE_SUPABASE_URL
#   anon public  → VITE_SUPABASE_PUBLISHABLE_KEY
VITE_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=your_anon_public_key

# ── ShalyaMitra GPU Backend ───────────────────────────────
# Production (during active slot):   https://gpu.shalyamitra.quaasx108.com
# Local development:                 http://localhost:9000
VITE_BACKEND_URL=https://gpu.shalyamitra.quaasx108.com

# ── Demo mode ─────────────────────────────────────────────
# false = production (real API calls)
# true  = demo-only UI paths (no GPU needed)
VITE_DEMO_MODE=false

# Local owner/dev bypass (skip Supabase auth in UI for private testing).
# Keep false for production.
VITE_DEV_AUTH_BYPASS=false
VITE_DEV_OWNER_ID=00000000-0000-0000-0000-000000000001
VITE_DEV_OWNER_EMAIL=owner@localhost
