# ══════════════════════════════════════════════════════════
# ShalyaMitra Backend — Environment Variables (GPU slot)
# ══════════════════════════════════════════════════════════
# Copy to gpu-stack/.env and fill in your values.
# These are loaded by docker-compose.gpu.yml.
#
# Production domain layout:
#   gpu.shalyamitra.quaasx108.com  → Cloudflare → Nginx :80 → FastAPI :9000
#   shalyamitra.quaasx108.com      → Vercel frontend (always-on)
#   Supabase             → Auth + DB (always-on)
#   LiveKit Cloud        → WebRTC (always-on, pay-per-room-minute)
# ══════════════════════════════════════════════════════════

# ── App ────────────────────────────────────────────────
DEBUG=false
RUNTIME_MODE=production
ENABLE_DEMO_MODE=false
# Local owner/dev bypass (Supabase auth optional for private testing).
# Keep false for production.
DEV_AUTH_BYPASS=false
DEV_AUTH_BYPASS_SUB=00000000-0000-0000-0000-000000000001
DEV_AUTH_BYPASS_EMAIL=owner@localhost
DEV_AUTH_BYPASS_ROLE=admin

# ── Supabase (from your project settings) ─────────────
# Dashboard → Project Settings → API
SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key
SUPABASE_JWT_SECRET=your_supabase_jwt_secret

# ── GPU Provider ──────────────────────────────────────
# lightning = Lightning AI H100 (slot-based, this file)
GPU_PROVIDER=lightning
GPU_BACKEND_URL=
GPU_BACKEND_TOKEN=

# ── Slot identity (set by slot-start.sh automatically) ─
# Slot ID from booking system — used for audit trails
SLOT_ID=

# ── LiveKit Cloud (production — pay per room-minute) ──
# Dashboard: https://cloud.livekit.io → project → Settings
# Format: wss://YOUR_PROJECT.livekit.cloud
LIVEKIT_URL=wss://your-project.livekit.cloud
LIVEKIT_API_KEY=APIxxxxxxxxxxxxxxxx
LIVEKIT_API_SECRET=your_livekit_api_secret

# ── Redis ─────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ── Qdrant ────────────────────────────────────────────
QDRANT_URL=http://localhost:6333

# ── OpenRouter (fallback only — NIM API is primary) ──
OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
LLM_PROVIDER=openrouter
OPENROUTER_PRIMARY_MODEL=google/gemini-2.0-flash-001
OPENROUTER_THINKING_MODEL=moonshotai/kimi-k2.5
OPENROUTER_FAST_MODEL=google/gemini-2.0-flash-001
OPENROUTER_VISION_MODEL=google/gemini-2.0-flash-001

# ── NVIDIA NIM API (PRIMARY inference engine) ─────────
# Get your free key at: https://build.nvidia.com
# Free tier: 1,000 API calls/month. No GPU needed.
# This single key activates ALL 5 NIM models below.
NVIDIA_API_KEY=nvapi-xxxxxxxxxxxxxxxxxxxxxxxxxxxx

# NIM model overrides (defaults set in config.py)
# NIM_REASONING_MODEL=nvidia/llama-3.3-nemotron-super-49b-v1
# NIM_THINKING_MODEL=moonshotai/kimi-k2.5
# NIM_FAST_MODEL=nvidia/nemotron-3-nano-30b-a3b
# NIM_VISION_MODEL=nvidia/nemotron-nano-12b-v2-vl
# NIM_SAFETY_MODEL=nvidia/nemotron-content-safety-reasoning-4b

# ── NVIDIA Riva (on GPU instance) ────────────────────
RIVA_GRPC_URL=localhost:50051
# HTTP/Triton base for ASR/TTS/NMT REST (align with your Riva deployment; docker: http://riva:8000)
RIVA_HTTP_BASE=http://localhost:8000
RIVA_TTS_ENABLE=true
RIVA_NMT_ENABLE=true
RIVA_TTS_VOICE=English-US.Female-1
# Optional: domain acoustic model name after fine-tune in Riva
# RIVA_ACOUSTIC_MODEL=

# ── Holoscan bridge (HoloHub / vision live) ───────────
# Probed for holoscan_live mode (docker: http://holoscan-bridge:9100)
HOLOSCAN_BASE_URL=http://localhost:9100
VIDEO_INGEST_MODE=webrtc
# Optional: holoscan-bridge → agent (docker internal)
INTERNAL_BUS_TOKEN=

# ── Fish Speech TTS (on GPU instance) ────────────────
FISH_SPEECH_URL=http://localhost:8080

# ── Piper TTS (critical alerts, on GPU instance) ─────
PIPER_URL=http://localhost:8090

# ── MinIO (file storage) ─────────────────────────────
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin

# ── Zero-Shot Instrument Detection (no training needed) ──
# Tier 1: Grounding DINO 1.5 Pro
# Apply for free API token: https://deepdataspace.com
# Without this, system falls back to Florence-2 (free, local)
GROUNDING_DINO_API_TOKEN=

# Tier 2: Florence-2 runs locally — no key needed
# First use downloads ~1.5GB model from HuggingFace automatically
FLORENCE2_ENABLED=true

# ── NIM / NGC operational flags ─────────────────────────
NIM_LIVE_TEST=true
NVIDIA_NIM_BASE_URL=https://integrate.api.nvidia.com/v1
NGC_API_KEY=

# ── OpenWakeWord (optional wake-word tier) ──────────────
OPENWAKEWORD_ENABLED=false
OPENWAKEWORD_THRESHOLD=0.6

# ── NemoClaw governance + MCP endpoints ────────────────
NEMOCLAW_ENABLED=true
# In docker compose agent container this is mounted as /nemoclaw/config
# NEMOCLAW_CONFIG_DIR=/nemoclaw/config
NEMOCLAW_CONFIG_DIR=
# Optional JSONL audit file path
NEMOCLAW_AUDIT_LOG_PATH=
MARMA_MCP_URL=http://127.0.0.1:3001
DRUG_MCP_URL=http://127.0.0.1:3002
SAFETY_MCP_URL=http://127.0.0.1:3003

