# ──────────────────────────────────────────────────────────
# ShalyaMitra Backend — Environment Variables Template
# ──────────────────────────────────────────────────────────
# Copy this to .env and fill in your values.
# ──────────────────────────────────────────────────────────

# ── App ────────────────────────────────────────────────
DEBUG=true

# ── Supabase (from your project settings) ─────────────
SUPABASE_URL=https://hkrimacqtydvbleorklw.supabase.co
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_JWT_SECRET=

# ── GPU Provider ──────────────────────────────────────
# Options: demo | nebius | lightning | local
GPU_PROVIDER=demo
GPU_BACKEND_URL=
GPU_BACKEND_TOKEN=

# ── LiveKit ───────────────────────────────────────────
LIVEKIT_URL=ws://localhost:7880
LIVEKIT_API_KEY=
LIVEKIT_API_SECRET=

# ── Redis ─────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ── Qdrant ────────────────────────────────────────────
QDRANT_URL=http://localhost:6333

# ── OpenRouter (fallback only — NIM API is primary) ──
OPENROUTER_API_KEY=

# ── NVIDIA NIM API (PRIMARY inference engine) ─────────
# Get your free key at: https://build.nvidia.com
# Free tier: 1,000 API calls/month. No GPU needed.
# This single key activates ALL 5 NIM models below.
NVIDIA_API_KEY=nvapi-xxxxxxxxxxxxxxxxxxxxxxxxxxxx

# NIM model overrides (defaults set in config.py)
# NIM_REASONING_MODEL=nvidia/llama-3.3-nemotron-super-49b-v1
# NIM_THINKING_MODEL=moonshotai/kimi-k2.5
# NIM_FAST_MODEL=nvidia/nemotron-3-nano-30b-a3b
# NIM_VISION_MODEL=nvidia/nemotron-nano-12b-v2-vl
# NIM_SAFETY_MODEL=nvidia/nemotron-content-safety-reasoning-4b

# ── NVIDIA Riva (on GPU instance) ────────────────────
RIVA_GRPC_URL=localhost:50051

# ── Fish Speech TTS (on GPU instance) ────────────────
FISH_SPEECH_URL=http://localhost:8080

# ── Piper TTS (critical alerts, on GPU instance) ─────
PIPER_URL=http://localhost:8090

# ── MinIO (file storage) ─────────────────────────────
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin

# ── Zero-Shot Instrument Detection (no training needed) ──
# Tier 1: Grounding DINO 1.5 Pro
# Apply for free API token: https://deepdataspace.com
# Without this, system falls back to Florence-2 (free, local)
GROUNDING_DINO_API_TOKEN=

# Tier 2: Florence-2 runs locally — no key needed
# First use downloads ~1.5GB model from HuggingFace automatically
FLORENCE2_ENABLED=true

