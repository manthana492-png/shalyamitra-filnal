# Copy to .env next to docker-compose.gpu.yml (do not commit real secrets)
# Silence compose warnings — values can be empty:
NVIDIA_API_KEY=
LLM_PROVIDER=openrouter
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_PRIMARY_MODEL=google/gemini-2.0-flash-001
OPENROUTER_THINKING_MODEL=moonshotai/kimi-k2.5
OPENROUTER_FAST_MODEL=google/gemini-2.0-flash-001
OPENROUTER_VISION_MODEL=google/gemini-2.0-flash-001

# Local owner/dev bypass (Supabase auth optional for private testing).
# Keep false for production.
DEV_AUTH_BYPASS=false
DEV_AUTH_BYPASS_SUB=00000000-0000-0000-0000-000000000001
DEV_AUTH_BYPASS_EMAIL=owner@localhost
DEV_AUTH_BYPASS_ROLE=admin

# Optional: start on-GPU Riva + Holoscan (see services/riva/README.md)
# COMPOSE_PROFILES=nvidia
# Optional override; default is NVIDIA cloud API
# NVIDIA_NIM_BASE_URL=https://integrate.api.nvidia.com/v1

# NGC — only if you use --profile local-nim or pull Riva/Holoscan from nvcr
NGC_API_KEY=
# LiveKit Cloud (production): wss://<project>.livekit.cloud
LIVEKIT_URL=wss://your-project.livekit.cloud
LIVEKIT_API_KEY=
LIVEKIT_API_SECRET=
OPENROUTER_API_KEY=

# Holoscan / LiveKit ingest: webrtc (phones) | hsb (Sensor Bridge + native video)
VIDEO_INGEST_MODE=webrtc
HOLOSCAN_BASE_URL=http://holoscan-bridge:9100
RIVA_HTTP_BASE=http://riva:8000
# Optional service-to-service auth for /api/internal/holoscan/*
# INTERNAL_BUS_TOKEN=
